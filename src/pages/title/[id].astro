---
import { readFile } from 'fs/promises';
import { join } from 'path';

export async function getStaticPaths() {
  let releases: any[] = [];
  try {
    const data = await readFile(join(process.cwd(), 'src/data/releases.json'), 'utf-8');
    releases = JSON.parse(data);
  } catch {}
  const unique = [...new Map(releases.map((item) => [item.id, item])).values()];
  return unique.slice(0, 1000).map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props as { item: any };
const baseUrl = import.meta.env.PUBLIC_SITE_URL || 'https://mangadrop.online';
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{item.title} release | MangaDrop</title>
    <meta name="description" content={`${item.title} release date, author and source link.`} />
    <link rel="canonical" href={`${baseUrl}/title/${item.id}`} />
    <meta property="og:url" content={`${baseUrl}/title/${item.id}`} />
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-G0YE8ZCN66"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-G0YE8ZCN66', { page_path: window.location.pathname });
    </script>
    <link rel="stylesheet" href="/global.css" />
  </head>
  <body class="bg-rose-50 text-slate-900">
    <header class="border-b bg-white">
      <div class="mx-auto flex max-w-6xl items-center justify-between p-4">
        <a href="/" class="text-2xl font-bold text-rose-600">MangaDrop</a>
        <a href="/calendar" class="text-sm hover:text-rose-600">Calendar</a>
      </div>
    </header>
    <main class="mx-auto max-w-4xl px-4 py-10">
      <h1 class="text-4xl font-bold">{item.title}</h1>
      <p class="mt-2 text-slate-600">{item.originalTitle || item.author}</p>
      <div class="mt-6 rounded-xl border bg-white p-6">
        <dl class="grid gap-4 sm:grid-cols-2">
          <div><dt class="text-xs uppercase text-slate-500">Release date</dt><dd class="mt-1 font-semibold">{item.releaseDate}</dd></div>
          <div><dt class="text-xs uppercase text-slate-500">Format</dt><dd class="mt-1 font-semibold">{item.format}</dd></div>
          <div><dt class="text-xs uppercase text-slate-500">Author</dt><dd class="mt-1 font-semibold">{item.author || '-'}</dd></div>
          <div><dt class="text-xs uppercase text-slate-500">Source</dt><dd class="mt-1 font-semibold">{item.source}</dd></div>
        </dl>
        {item.url && <a href={item.url} target="_blank" rel="noopener noreferrer" class="mt-6 inline-block rounded-lg bg-rose-600 px-5 py-2 text-white hover:bg-rose-700">Open source</a>}
      </div>

      <section class="mt-8 rounded-xl border bg-white p-6">
        <h2 class="text-xl font-semibold">Release context</h2>
        <p class="mt-3 leading-7 text-slate-700">
          This title page keeps the essential release details on MangaDrop before any external click. Check the format, author, original title,
          source label, and release date together so you can decide whether the update is worth tracking, bookmarking, or comparing with another edition.
        </p>
        <p class="mt-3 leading-7 text-slate-700">
          If the title has multiple editions, compare this entry with the calendar and format boards before leaving the site.
          Manga, webtoon, and light novel releases can share similar names while following very different publication schedules,
          so the safest next step is to verify the author, release window, and source label together.
        </p>
        <div class="mt-5 grid gap-3 md:grid-cols-3">
          <div class="rounded-lg bg-rose-50 p-4 text-sm leading-6">
            <strong>Before reading:</strong> confirm whether the entry is manga, webtoon, or light novel because publication cadence differs.
          </div>
          <div class="rounded-lg bg-rose-50 p-4 text-sm leading-6">
            <strong>Before sharing:</strong> use the title and source shown here rather than copying only a raw external link.
          </div>
          <div class="rounded-lg bg-rose-50 p-4 text-sm leading-6">
            <strong>Before following:</strong> compare release date movement with the calendar page for nearby updates.
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
