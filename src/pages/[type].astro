---
import releases from '../data/releases.json';

const types = ['manga', 'webtoon', 'lightnovel'];

export function getStaticPaths() {
  return types.map((type) => ({ params: { type } }));
}

const { type } = Astro.params;
const baseUrl = import.meta.env.PUBLIC_SITE_URL || 'https://mangadrop.online';
const labelMap: Record<string, string> = { manga: 'Manga', webtoon: 'Webtoon', lightnovel: 'Light novel' };
const items = (releases as any[]).filter((item) => item.format === type).slice(0, 100);
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{labelMap[type]} releases | MangaDrop</title>
    <meta name="description" content={`Upcoming and recent ${labelMap[type]} release tracker.`} />
    <link rel="canonical" href={`${baseUrl}/${type}`} />
    <meta property="og:url" content={`${baseUrl}/${type}`} />
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-G0YE8ZCN66"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-G0YE8ZCN66', { page_path: window.location.pathname });
    </script>
    <link rel="stylesheet" href="/global.css" />
  </head>
  <body class="bg-rose-50 text-slate-900">
    <header class="border-b bg-white">
      <div class="mx-auto flex max-w-6xl items-center justify-between p-4">
        <a href="/" class="text-2xl font-bold text-rose-600">MangaDrop</a>
        <a href="/calendar" class="text-sm hover:text-rose-600">Calendar</a>
      </div>
    </header>
    <main class="mx-auto max-w-6xl px-4 py-10">
      <h1 class="text-4xl font-bold">{labelMap[type]} releases</h1>
      <p class="mt-3 text-slate-600">Release dates, source links and cover art for tracked titles.</p>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {items.map((item) => (
          <a href={`/title/${encodeURIComponent(item.id)}`} class="rounded-xl border bg-white p-5 hover:border-rose-400">
            <div class="font-semibold">{item.title}</div>
            <div class="mt-2 text-sm text-slate-500">{item.releaseDate} · {item.source}</div>
          </a>
        ))}
      </div>
    </main>
  </body>
</html>
