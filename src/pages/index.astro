---
import { readFile } from 'fs/promises';
import { join } from 'path';

interface Release {
  id: string;
  title: string;
  originalTitle?: string;
  author?: string;
  publisher?: string;
  releaseDate: string;
  format: 'manga' | 'webtoon' | 'lightnovel';
  source: string;
  coverUrl?: string;
  url?: string;
  countryCode: 'KR' | 'JP';
  volumeNumber?: number;
}

let releases: Release[] = [];
try {
  const data = await readFile(join(process.cwd(), 'src/data/releases.json'), 'utf-8');
  releases = JSON.parse(data);
} catch {}

const today = new Date().toISOString().slice(0, 10);
const upcoming = releases.filter((r) => r.releaseDate >= today).slice(0, 24);
const recent = releases.filter((r) => r.releaseDate < today).slice(0, 24);

const baseUrl = import.meta.env.PUBLIC_SITE_URL || 'https://mangadrop.online';
const coupangUrl = import.meta.env.PUBLIC_COUPANG_PARTNER_URL || 'https://www.coupang.com/np/search?component=&q=%EB%A7%8C%ED%99%94%20%EB%8B%A8%ED%96%89%EB%B3%B8';
const aliExpressUrl = import.meta.env.PUBLIC_ALIEXPRESS_PARTNER_URL || 'https://www.aliexpress.com/w/wholesale-manga-merchandise.html';
const amazonUrl = 'https://www.amazon.com/s?k=manga+box+set&tag=amazonfi00681-20&linkCode=ll2';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Google Analytics 4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-G0YE8ZCN66"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-G0YE8ZCN66', { page_path: window.location.pathname });
    </script>
    <title>MangaDrop — 만화·웹툰·라노벨 신간 발매 캘린더</title>
    <meta name="description" content="한국·일본 만화·웹툰·라이트노벨 신간 발매 일정 통합. 알라딘·MyAnimeList·출판사 RSS를 매일 동기화." />
    <meta name="keywords" content="만화 신간, 웹툰 발매, 라이트노벨 발매일, 만화 캘린더, manga release, webtoon, light novel, 알라딘 만화, 점프 코믹스" />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="theme-color" content="#e11d48" />
    <link rel="stylesheet" href="/global.css" />
    <link rel="canonical" href={baseUrl} />
    <!-- hreflang for international SEO -->
    <link rel="alternate" hreflang="ko" href={baseUrl} />
    <link rel="alternate" hreflang="ja" href={`${baseUrl}/ja/`} />
    <link rel="alternate" hreflang="en" href={`${baseUrl}/en/`} />
    <link rel="alternate" hreflang="x-default" href={baseUrl} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="MangaDrop — 만화·웹툰·라노벨 신간 발매 캘린더" />
    <meta property="og:description" content="한국·일본 만화·웹툰·라이트노벨 신간 발매 일정 통합. 매일 자동 동기화." />
    <meta property="og:url" content={baseUrl} />
    <meta property="og:site_name" content="MangaDrop" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:locale:alternate" content="ja_JP" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="og:image" content={`${baseUrl}/og.png`} />
    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="MangaDrop — 만화·웹툰·라노벨 신간 발매 캘린더" />
    <meta name="twitter:description" content="한국·일본 만화·웹툰·라이트노벨 신간 발매 일정 통합. 매일 자동 동기화." />
    <meta name="twitter:image" content={`${baseUrl}/og.png`} />
    <!-- Schema.org JSON-LD: Organization + WebSite + ItemList -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": `${baseUrl}/#org`,
          "name": "MangaDrop",
          "url": baseUrl,
          "logo": `${baseUrl}/og.png`,
          "sameAs": []
        },
        {
          "@type": "WebSite",
          "@id": `${baseUrl}/#site`,
          "url": baseUrl,
          "name": "MangaDrop",
          "description": "만화·웹툰·라이트노벨 신간 발매 캘린더",
          "inLanguage": "ko-KR",
          "publisher": { "@id": `${baseUrl}/#org` },
          "potentialAction": {
            "@type": "SearchAction",
            "target": `${baseUrl}/?q={search_term_string}`,
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "BreadcrumbList",
          "itemListElement": [
            { "@type": "ListItem", "position": 1, "name": "Home", "item": baseUrl },
            { "@type": "ListItem", "position": 2, "name": "만화", "item": `${baseUrl}/manga` },
            { "@type": "ListItem", "position": 3, "name": "웹툰", "item": `${baseUrl}/webtoon` },
            { "@type": "ListItem", "position": 4, "name": "라노벨", "item": `${baseUrl}/lightnovel` },
            { "@type": "ListItem", "position": 5, "name": "발매 달력", "item": `${baseUrl}/calendar` }
          ]
        },
        ...(upcoming.length > 0 ? [{
          "@type": "ItemList",
          "name": "예정 발매",
          "numberOfItems": upcoming.length,
          "itemListElement": upcoming.slice(0, 10).map((r, i) => ({
            "@type": "ListItem",
            "position": i + 1,
            "name": r.title,
            "url": r.url || `${baseUrl}/#${r.id}`
          }))
        }] : []),
        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "MangaDrop은 어디 데이터를 동기화하나요?",
              "acceptedAnswer": { "@type": "Answer", "text": "알라딘 신간 RSS, MyAnimeList API, 일본 출판사(Shueisha, Kodansha, KakaoPage 등) RSS를 매일 자동으로 동기화합니다." }
            },
            {
              "@type": "Question",
              "name": "발매 알림을 받을 수 있나요?",
              "acceptedAnswer": { "@type": "Answer", "text": "네. 작품을 즐겨찾기에 추가하면 발매일 알림을 받을 수 있습니다." }
            },
            {
              "@type": "Question",
              "name": "회원가입 필요한가요?",
              "acceptedAnswer": { "@type": "Answer", "text": "아니요. 발매 일정 조회는 회원가입 없이 즉시 가능합니다." }
            }
          ]
        }
      ]
    })} />
    <script is:inline>
  window.addEventListener('click', function(event) {
    var link = event.target && event.target.closest ? event.target.closest('a[rel*="sponsored"], [data-affiliate-link]') : null;
    if (!link || typeof window.gtag !== 'function') return;
    window.gtag('event', 'affiliate_click', {
      merchant: (link.textContent || '').trim().slice(0, 60) || 'partner',
      placement: link.getAttribute('data-placement') || link.getAttribute('aria-label') || 'sponsored-link',
      page_location: window.location.href
    });
  }, { capture: true });
</script>
</head>
  <body class="bg-stone-50 text-stone-900 antialiased">
    <header class="border-b bg-white">
      <div class="container mx-auto flex max-w-6xl items-center justify-between p-4">
        <a href="/" class="text-2xl font-bold text-rose-600">MangaDrop</a>
        <nav class="flex gap-3 text-sm">
          <a href="/manga" class="hover:text-rose-600">만화</a>
          <a href="/webtoon" class="hover:text-rose-600">웹툰</a>
          <a href="/lightnovel" class="hover:text-rose-600">라노벨</a>
          <a href="/calendar" class="hover:text-rose-600">달력</a>
        </nav>
      </div>
    </header>

    <section class="bg-gradient-to-br from-rose-50 to-white py-10">
      <div class="container mx-auto max-w-6xl px-4 text-center">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight">신간이 매일 떨어진다</h1>
        <p class="mt-3 text-stone-600">한국·일본 만화·웹툰·라이트노벨 발매 일정을 매일 동기화.</p>
      </div>
    </section>

    {upcoming.length > 0 && (
      <section class="container mx-auto max-w-6xl px-4 py-8">
        <h2 class="mb-4 text-2xl font-semibold">📅 예정 발매</h2>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {upcoming.map((r) => (
            <a
              href={r.url || '#'}
              target="_blank"
              rel="noopener"
              class="group block rounded-lg overflow-hidden bg-white border hover:border-rose-400 transition hover:scale-105"
            >
              {r.coverUrl ? (
                <img src={r.coverUrl} alt={r.title} class="aspect-[2/3] w-full object-cover" />
              ) : (
                <div class="aspect-[2/3] w-full bg-stone-200" />
              )}
              <div class="p-2">
                <div class="line-clamp-2 text-xs font-medium">{r.title}</div>
                <div class="mt-1 text-[10px] text-stone-500">
                  {r.releaseDate} · {r.countryCode}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {recent.length > 0 && (
      <section class="container mx-auto max-w-6xl px-4 py-8">
        <h2 class="mb-4 text-2xl font-semibold">최근 발매</h2>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {recent.map((r) => (
            <a
              href={r.url || '#'}
              target="_blank"
              rel="noopener"
              class="group block rounded-lg overflow-hidden bg-white border hover:border-rose-400 transition"
            >
              {r.coverUrl && <img src={r.coverUrl} alt={r.title} class="aspect-[2/3] w-full object-cover" />}
              <div class="p-2">
                <div class="line-clamp-2 text-xs font-medium">{r.title}</div>
                <div class="mt-1 text-[10px] text-stone-500">{r.releaseDate}</div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="container mx-auto max-w-6xl px-4 pb-10">
      <div class="rounded-xl border bg-white p-5">
        <h2 class="mb-2 text-2xl font-semibold">Partner Picks</h2>
        <p class="mb-4 text-sm text-stone-600">만화/굿즈/정리용품 관련 추천 링크입니다.</p>
        <div class="grid gap-3 sm:grid-cols-3">
          <a href={amazonUrl} target="_blank" rel="sponsored noopener noreferrer nofollow" class="rounded-lg border border-amber-300 bg-amber-50 p-4 hover:border-amber-400" data-affiliate-link>
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Amazon</p>
            <p class="mt-1 text-sm">Manga Box Set</p>
          </a>
          <a href={coupangUrl} target="_blank" rel="sponsored noopener noreferrer nofollow" class="rounded-lg border border-blue-300 bg-blue-50 p-4 hover:border-blue-400" data-affiliate-link>
            <p class="text-xs font-semibold uppercase tracking-wide text-blue-700">Coupang</p>
            <p class="mt-1 text-sm">만화 단행본</p>
          </a>
          <a href={aliExpressUrl} target="_blank" rel="sponsored noopener noreferrer nofollow" class="rounded-lg border border-rose-300 bg-rose-50 p-4 hover:border-rose-400" data-affiliate-link>
            <p class="text-xs font-semibold uppercase tracking-wide text-rose-700">AliExpress</p>
            <p class="mt-1 text-sm">Manga Merchandise</p>
          </a>
        </div>
      </div>
    </section>
  </body>
</html>
